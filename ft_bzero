#include <unistd.h>

void    bzero(void *s, size_t n)
{
    char*   ptr;
    int     i;

    ptr = (char*) s;
    i = 0;
    while (i < n)
    {
        *(ptr + i) = 0;
        ++i;
    }
    return (s);
}
